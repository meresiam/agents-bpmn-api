generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  tenantId  String
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]

  @@map("users")
  @@index([tenantId], name: "idx_users_tenant_id")
}

model Process {
  id          String           @id @default(uuid())
  tenantId    String
  slug        String
  title       String
  description String?
  category    ProcessCategory  @default(COMERCIAL)
  graph       Json
  version     Int              @default(1)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  threads     CommentThread[]
  stickyNotes StickyNote[]

  @@unique([tenantId, slug], name: "uq_process_tenant_slug")
  @@map("processes")
  @@index([tenantId], name: "idx_processes_tenant_id")
}

enum ProcessCategory {
  COMERCIAL
  MARKETING
  FINANCEIRO
  OPERACOES
  RH
  ATENDIMENTO
  ONBOARDING
  LOGISTICA
  JURIDICO
  TI
  OUTRO
}

model CommentThread {
  id         String    @id @default(uuid())
  processId  String
  process    Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
  x          Float
  y          Float
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]

  @@map("comment_threads")
  @@index([processId], name: "idx_comment_threads_process_id")
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  threadId  String
  thread    CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("comments")
  @@index([threadId], name: "idx_comments_thread_id")
}

model StickyNote {
  id        String       @id @default(uuid())
  processId String
  process   Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  content   String
  color     NoteColor    @default(YELLOW)
  x         Float
  y         Float
  width     Float        @default(200)
  height    Float        @default(120)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("sticky_notes")
  @@index([processId], name: "idx_sticky_notes_process_id")
}

enum NoteColor {
  YELLOW
  BLUE
  GREEN
  PINK
  ORANGE
  PURPLE
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("api_keys")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLIENT
}
